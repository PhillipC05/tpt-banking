# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tpt_banking
DATABASE_PASSWORD=tpt_banking_dev
DATABASE_NAME=tpt_banking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=tpt-banking
KAFKA_GROUP_ID=tpt-banking-group

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# App
NODE_ENV=development
PORT=3000
API_GATEWAY_PORT=3001
COMPLIANCE_PORT=3002
LOG_LEVEL=debug

# KYC provider (JUMIO or ONFIDO)
KYC_PROVIDER=JUMIO
APP_BASE_URL=http://localhost:3002

# Encryption
ENCRYPTION_KEY_PATH=vault

# CORS
CORS_ORIGINS=http://localhost:3002,http://localhost:3003

# Third-party integrations (Phase 2+)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

COMPLY_ADVANTAGE_API_KEY=
COMPLY_ADVANTAGE_BASE_URL=https://api.complyadvantage.com

JUMIO_API_TOKEN=
JUMIO_API_SECRET=
JUMIO_BASE_URL=https://netverify.com

ONFIDO_API_TOKEN=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email provider: sendgrid | ses | postmark | smtp  (auto-detected if omitted)
EMAIL_PROVIDER=
EMAIL_FROM=noreply@tptbanking.com

# SendGrid
SENDGRID_API_KEY=

# AWS SES  (region required; credentials optional if running on EC2/ECS with IAM role)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Postmark
POSTMARK_SERVER_TOKEN=

# SMTP (generic — works with Mailgun relay, Office 365, Gmail SMTP, self-hosted Postfix, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Open Banking
OPEN_BANKING_SIGNING_KEY_PATH=./keys/ob-signing.pem
OPEN_BANKING_TRANSPORT_KEY_PATH=./keys/ob-transport.pem

# Database pool (optional tuning)
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2
DATABASE_SSL=false
DATABASE_RUN_MIGRATIONS=false
